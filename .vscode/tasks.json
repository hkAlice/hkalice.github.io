{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Jekyll Server",
      "type": "shell",
      "command": "./tools/run.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Runs the Jekyll server with live reload."
    },
    {
      "label": "Build Jekyll Site",
      "type": "shell",
      "command": "./tools/test.sh",
      "group": {
        "kind": "build"
      },
      "problemMatcher": [],
      "detail": "Build the Jekyll site for production."
    },
    {
      "label": "Create New Post",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\new-post.ps1",
        "-Title",
        "${input:postTitle}",
        "-Categories",
        "${input:postCategories}",
        "-Tags",
        "${input:postTags}"
      ],
      "problemMatcher": [],
      "detail": "Creates a new post with optional categories and tags."
    }
  ],
  "inputs": [
    {
      "id": "postTitle",
      "type": "promptString",
      "description": "Post title",
      "default": "My New Post"
    },
    {
      "id": "postCategories",
      "type": "promptString",
      "description": "Comma-separated categories (optional)",
      "default": ""
    },
    {
      "id": "postTags",
      "type": "promptString",
      "description": "Comma-separated tags (optional)",
      "default": ""
    }
  ]
}
